rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cualquier usuario autenticado puede verificar si está autorizado
    match /authorizedUsers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Solo usuarios autorizados pueden acceder al resto de los datos
    match /{document=**} {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/authorizedUsers/$(request.auth.uid));
    }
  }
}
